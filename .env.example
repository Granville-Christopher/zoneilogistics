# MongoDB connection string
# Local:
MONGODB_URI=mongodb://127.0.0.1:27017/zoneiintl

# Or MongoDB Atlas:
# MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/zoneiintl?retryWrites=true&w=majority

PORT=3000

# Required for admin auth (use long random strings in production)
JWT_SECRET=change-me-to-a-long-random-secret
# Required after the first admin exists — share only with trusted staff
ADMIN_INVITE_CODE=change-me-to-a-private-invite-code
